<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/card_background"
    app:shimmer_auto_start="true"
    app:shimmer_base_alpha="0.3"
    app:shimmer_duration="1200"
    app:shimmer_highlight_alpha="0.7"
    app:shimmer_shape="linear">

    <!-- Main container: uses weights to split the screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Media area – takes 60% of the height (weight 3 of 5) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="@color/shimmer_color" />

        <!-- Content area – takes 40% of the height (weight 2 of 5) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header row: icon + text lines -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Icon placeholder -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/shimmer_color" />

                <!-- Text column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Headline placeholder -->
                    <View
                        android:layout_width="180dp"
                        android:layout_height="20dp"
                        android:background="@color/shimmer_color" />

                    <!-- Advertiser placeholder -->
                    <View
                        android:layout_width="120dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/shimmer_color" />
                </LinearLayout>
            </LinearLayout>

            <!-- Body text placeholders -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:layout_marginTop="20dp"
                android:background="@color/shimmer_color" />

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:layout_marginTop="8dp"
                android:background="@color/shimmer_color" />

            <View
                android:layout_width="180dp"
                android:layout_height="16dp"
                android:layout_marginTop="8dp"
                android:background="@color/shimmer_color" />

            <!-- Spacer to push CTA to bottom -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Call‑to‑action button placeholder -->
            <View
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@color/shimmer_color" />
        </LinearLayout>
    </LinearLayout>
</com.facebook.shimmer.ShimmerFrameLayout>